{
  "name": "task-managment-api",
  "version": "1.0.0",
  "type": "module",
  "description": "Express TypeScript backend scaffold.",
  "license": "ISC",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "npm run lint && tsc",
    "lint": "eslint src",
    "start": "node dist/server.js",
    "generate": "npm run build && drizzle-kit generate --config src/drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config src/drizzle.config.ts",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:reset:dev": "cross-env NODE_ENV=development tsx src/db/resetDb.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
